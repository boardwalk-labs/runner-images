# Kernel options the Boardwalk Firecracker guest substrate REQUIRES. build_kernel.sh fails
# the build unless every non-comment line below appears verbatim in the final .config —
# so bumping KERNEL_VERSION or FC_TAG can never silently drop a capability the runner needs.
#
# Device set = what Firecracker emulates; capabilities = what the runner substrate uses.

# virtio transport (Firecracker exposes devices over MMIO, not PCI)
CONFIG_VIRTIO_MMIO=y

# root disk
CONFIG_VIRTIO_BLK=y
CONFIG_EXT4_FS=y

# network (egress via the host's tap/veth path)
CONFIG_VIRTIO_NET=y

# vsock — the host-agent control channel (run identity injection, suspend/wake)
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# guest entropy feed
CONFIG_HW_RANDOM_VIRTIO=y

# device nodes at init — no initramfs and no udev in this boot model, so /dev/vda and
# /dev/vsock exist only if the kernel populates devtmpfs and mounts it on /dev itself
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# serial console (console=ttyS0) — the boot log and the smoke gate's verdict channel;
# without it a broken image fails mutely instead of tellingly
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# sysrq — the clean-poweroff path for guests whose rootfs has no reboot binary
CONFIG_MAGIC_SYSRQ=y

# kvmclock — sane guest timekeeping, load-bearing across snapshot restores
CONFIG_KVM_GUEST=y

# VMGenID: the ACPI generation counter that tells the kernel a snapshot restore happened,
# triggering an in-kernel CSPRNG reseed. Required for safe snapshot clones. Needs ACPI.
CONFIG_ACPI=y
CONFIG_VMGENID=y

# read-only base rootfs + per-VM writable overlay
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
