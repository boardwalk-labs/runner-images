# Boardwalk — flat dark openbox theme for the ambient desktop. One thin dark titlebar
# (label only — rc.xml titleLayout drops the buttons), hairline borders, no gradients.
border.width: 1
padding.width: 12
padding.height: 7
window.handle.width: 0
window.client.padding.width: 0
window.client.padding.height: 0

window.active.border.color: #2a3542
window.inactive.border.color: #222b35
window.active.title.separator.color: #10161d
window.inactive.title.separator.color: #10161d

window.active.title.bg: flat solid
window.active.title.bg.color: #10161d
window.active.label.bg: parentrelative
window.active.label.text.color: #dbe8f2
window.active.label.text.justify: center

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #10161d
window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #7f93a6
window.inactive.label.text.justify: center

menu.border.width: 1
menu.border.color: #2a3542
menu.title.bg: flat solid
menu.title.bg.color: #10161d
menu.title.text.color: #dbe8f2
menu.items.bg: flat solid
menu.items.bg.color: #141b23
menu.items.text.color: #dbe8f2
menu.items.active.bg: flat solid
menu.items.active.bg.color: #22303e
menu.items.active.text.color: #ffffff
